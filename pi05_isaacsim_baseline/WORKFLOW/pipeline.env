# ============================================================================
# pipeline.env — ONE place to configure the whole teleop → train → infer flow.
# Every WORKFLOW/*.sh script sources this file. Edit values here, not in scripts.
# ============================================================================

# --- Task (fixed across the whole pipeline; sim + dataset + eval must match) ---
TASK="Isaac-Stack-Cube-Franka-IK-Rel-v0"
ACTION_SPACE="ik_rel"                 # 7-D [dx,dy,dz,drx,dry,drz,gripper]
TASK_INSTRUCTION="Stack the cubes with the Franka robot."

# --- Teleoperation device (the standard sim-data-collection device) ---
# Built-ins that work today: keyboard, spacemouse, gamepad.
# GELLO leader arm needs a custom Se3Gello device (joint->EE-delta) — see README §Teleop.
TELEOP_DEVICE="keyboard"

# --- Collection ---
NUM_DEMOS=10
ENABLE_CAMERAS=1                      # 1 = record front/wrist RGB (needed for a visual VLA)

# --- Dataset / storage ---
# repo-id == the dataset folder name under data/lerobot/<REPO_ID>. Keep real and
# synthetic datasets in DIFFERENT repo-ids so they never mix.
REPO_ID="franka_stack_cube"
# When the HDF5 has NO cameras (state-only / plumbing test), set to e.g. 224 to inject
# zero images so it matches the pi0.5 input layout. For REAL camera data, leave 0.
SYNTH_IMAGES=0

# --- Training (pi0.5 LoRA low-mem; fits one 48 GB GPU) ---
CONFIG_NAME="pi05_isaaclab_franka"    # OpenPI config name injected by register_openpi_config.py
TRAIN_STEPS=10                        # smoke default; raise to 3000+ for a real run
BATCH_SIZE=1
FSDP=1                                # >1 shards across GPUs (needs even batch); see README

# --- Serving / inference / eval ---
PORT=8008                             # policy server HTTP port
NUM_ROLLOUTS=10
MAX_STEPS=200
IMAGE_MODE="none"                     # none | path | base64  (eval-time obs images)
